    "@types/node": "^25.3.5",
    "@vercel/sandbox": "^1.8.0",
    "dotenv": "^17.3.1",
    "e2b": "^2.14.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@blaxel/core": "^0.1.0",
    "@cloudflare/sandbox": "^0.1.0",
    "@daytonaio/sdk": "^0.12.0 || ^1.0.0",
